NODE_ENV=development
PORT=4050
PUBLIC_BASE_URL=http://localhost:4050
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

HOSTNAME=localhost
USER_NAME=root
PASSWORD=
DATABASE=dog_park_social

GOOGLE_PLACES_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4050/api/owners/google/callback
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=http://localhost:4050/api/owners/apple/callback
FRONTEND_BASE_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
# Development only: lets Google OAuth complete when the local database is unreachable.
AUTH_DB_FALLBACK=true

# Optional HTTPS in production. If omitted, the API starts with HTTP.
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=

# Production standalone defaults:
# NODE_ENV=production
# PUBLIC_BASE_URL=https://api.example.com
# FRONTEND_BASE_URL=https://app.example.com
# CORS_ORIGINS=https://app.example.com
# SESSION_SECRET=<at-least-32-random-characters>
# COOKIE_SECURE=true
# AUTH_DB_FALLBACK=false
